<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Layer 1: Camera live preview (real world background) -->
    <TextureView
        android:id="@+id/cameraTextureView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"/>

    <!-- Layer 2: OpenGL surface (transparent — renders floating video screen) -->
    <android.opengl.GLSurfaceView
        android:id="@+id/glSurfaceView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Layer 3: UI overlay -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Back button -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="top|start"
            android:layout_margin="16dp"
            android:background="@drawable/bg_circle_dark"
            android:contentDescription="@string/btn_back"
            android:src="@android:drawable/ic_media_previous"
            android:tint="@color/white"
            android:padding="10dp"/>

        <!-- Reset orientation button -->
        <ImageButton
            android:id="@+id/btnReset"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="top|end"
            android:layout_margin="16dp"
            android:background="@drawable/bg_circle_dark"
            android:contentDescription="@string/btn_reset"
            android:src="@android:drawable/ic_menu_compass"
            android:tint="@color/white"
            android:padding="10dp"/>

        <!-- Hint text (loading / instructions) -->
        <TextView
            android:id="@+id/tvHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="40dp"
            android:background="#AA000000"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="@string/hint_loading"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:visibility="visible"/>

    </FrameLayout>

</FrameLayout>
