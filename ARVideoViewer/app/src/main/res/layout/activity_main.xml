<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:padding="24dp">

    <!-- App icon / logo area -->
    <TextView
        android:id="@+id/tvLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="@color/text_primary"
        android:textSize="32sp"
        android:fontFamily="sans-serif-light"
        android:letterSpacing="0.1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="72dp"/>

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/subtitle"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/tvLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"/>

    <!-- Feature bullets -->
    <LinearLayout
        android:id="@+id/llFeatures"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/feature_1"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/feature_2"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/feature_3"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"/>
    </LinearLayout>

    <!-- Pick video button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPickVideo"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/btn_pick_video"
        android:textSize="16sp"
        android:textColor="@color/white"
        app:backgroundTint="@color/accent_blue"
        app:cornerRadius="28dp"
        app:layout_constraintBottom_toTopOf="@id/btnDemo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp"/>

    <!-- Demo button (no video, just sensor) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDemo"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/btn_demo"
        android:textSize="16sp"
        android:textColor="@color/text_primary"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        app:strokeColor="@color/accent_blue"
        app:cornerRadius="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="48dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
